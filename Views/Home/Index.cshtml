@model ArtistryHub.Models.CraftAI

<style>
    :root { --accent: #38bdf8; --bg-dark: #0f172a; }
    body { background: var(--bg-dark); color: #f1f5f9; font-family: 'Plus Jakarta Sans', sans-serif; }
    .art-card { background: rgba(30, 41, 59, 0.8); backdrop-filter: blur(20px); border: 1px solid #334155; border-radius: 28px; padding: 45px; box-shadow: 0 25px 60px rgba(0,0,0,0.5); }
    .roadmap-step { background: rgba(255,255,255,0.03); border-left: 4px solid var(--accent); padding: 20px; margin-bottom: 15px; border-radius: 0 15px 15px 0; transition: 0.3s; }
    .roadmap-step:hover { background: rgba(56, 189, 248, 0.1); transform: translateX(10px); }
    .img-preview { width: 100%; height: 380px; object-fit: cover; border-radius: 20px; border: 2px solid var(--accent); margin: 25px 0; }
    .neon-title { font-weight: 800; background: linear-gradient(to right, #fff, var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="art-card">
                <div class="text-center mb-5">
                    <h1 class="display-4 neon-title">ARTISAN CORE v3.0</h1>
                    <p class="text-secondary">Universal Roadmap Generator for Multidisciplinary Arts</p>
                    
                    <form asp-action="Analyze" method="post" class="mt-4">
                        <div class="input-group input-group-lg shadow-sm">
                            <input type="text" name="itemName" class="form-control bg-dark text-white border-secondary" placeholder="Enter Category: Painting, Web Design, Crochet, or Dress..." required />
                            <button type="submit" class="btn btn-primary px-5 fw-bold">GENERATE ROADMAP</button>
                        </div>
                    </form>
                </div>

                @if (!string.IsNullOrEmpty(Model.ItemName))
                {
                    <div class="animate__animated animate__fadeIn">
                        @{
                            string q = Model.ItemName.ToLower();
                            string imgUrl = "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800"; // Default
                            string[] steps = new string[3];

                            if (q.Contains("paint")) {
                                imgUrl = "https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=800";
                                steps = new[] { "Surface Prep: Prime canvas with Gesso and block in light/shadow shapes.", "Development: Apply mid-tones and build textures using dry-brushing.", "Finalizing: Detail highlights and apply varnish for a museum-grade finish." };
                            }
                            else if (q.Contains("web") || q.Contains("design")) {
                                imgUrl = "https://images.unsplash.com/photo-1547658719-da2b51169166?w=800";
                                steps = new[] { "Wireframing: Define UX flow and layout structures in Figma/Adobe XD.", "Architecture: Build responsive UI components using CSS Grid and Flexbox.", "Deployment: Optimize assets and launch using Docker containers." };
                            }
                            else if (q.Contains("crochet") || q.Contains("wool")) {
                                imgUrl = "data:image/jpeg;base64,";
                                steps = new[] { "Foundation: Select hook size and create the base chain/magic ring.", "Structuring: Follow the pattern rows, maintaining consistent yarn tension.", "Finishing: Weave in ends and block the item to hold its aesthetic shape." };
                            }
                            else if (q.Contains("dress") || q.Contains("fashion")) {
                                imgUrl = "https://images.unsplash.com/photo-1539109136881-3be0616acf4b?w=800";
                                steps = new[] { "Drafting: Take precise measurements and create paper patterns/muslin mockups.", "Construction: Source premium fabric and assemble main panels with reinforced seams.", "Couture Details: Hand-stitch embellishments and perform final fitting adjustments." };
                            }
                            else {
                                steps = new[] { "Research: Study your medium and gather all necessary resources.", "Drafting: Create a prototype or rough sketch of your final vision.", "Execution: Build the project and refine based on initial results." };
                            }
                        }

                        <div class="row align-items-center">
                            <div class="col-md-5">
                                <img src="@imgUrl" class="img-preview shadow-lg" alt="Art Category">
                            </div>
                            <div class="col-md-7 px-4">
                                <h3 class="mb-4 text-info">Strategic Roadmap</h3>
                                <div class="roadmap-step"><strong>Phase 01: Concept</strong><br><small>@steps[0]</small></div>
                                <div class="roadmap-step"><strong>Phase 02: Execution</strong><br><small>@steps[1]</small></div>
                                <div class="roadmap-step"><strong>Phase 03: Precision</strong><br><small>@steps[2]</small></div>
                            </div>
                        </div>

                        <div class="mt-4 p-4 rounded bg-dark border border-secondary">
                            <h5 class="text-primary">✨ Extra-Ordinary Strategy:</h5>
                            <p class="mb-0 text-muted">@Model.ProTip - Mix traditional methods with modern tech (like @(q.Contains("web") ? "AI automation" : "augmented reality preview")) to double the market value.</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>